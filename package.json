{
  "name": "kinematica",
  "productName": "Kinematica",
  "version": "1.0.0",
  "description": "Kinematica — robotics math, made visible. An interactive visualizer for vectors, dot/cross products, coordinate frames, transforms, rotations, eigenvectors, and singularities.",
  "license": "MIT",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^31.7.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.kinematica.viz",
    "productName": "Kinematica",
    "files": ["main.js", "kinematica.html", "package.json"],
    "directories": { "output": "dist" },
    "win": { "target": "nsis" },
    "mac": { "target": "dmg", "category": "public.app-category.education" },
    "linux": { "target": ["AppImage"], "category": "Education" }
  }
}
